rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────
    // Confirms the request comes from a signed-in user
    function isSignedIn() {
      return request.auth != null;
    }

    // Confirms the requesting user owns the resource
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Checks that only the listed fields are being written (prevents injection)
    function onlyFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Validates a number is within a safe range
    function inRange(val, min, max) {
      return val is number && val >= min && val <= max;
    }

    // ── /users/{uid} ──────────────────────────────────────────────────────
    match /users/{uid} {
      // Users can only read their own profile
      allow read: if isSignedIn() && isOwner(uid);

      // Only allow writes to safe fields — prevents privilege escalation
      allow create: if isSignedIn()
        && isOwner(uid)
        && request.resource.data.uid == uid;

      allow update: if isSignedIn()
        && isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(["uid", "email", "createdAt"]); // immutable fields

      allow delete: if false; // deletion handled by Cloud Functions only

      // ── /users/{uid}/daily_logs/{date} ──────────────────────────────────
      match /daily_logs/{date} {
        allow read:   if isSignedIn() && isOwner(uid);

        // Allow update but validate numeric field ranges to prevent abuse
        allow write: if isSignedIn()
          && isOwner(uid)
          && (
            !request.resource.data.keys().hasAny(["totalCalories"]) ||
            inRange(request.resource.data.totalCalories, 0, 20000)
          )
          && (
            !request.resource.data.keys().hasAny(["waterMl"]) ||
            inRange(request.resource.data.waterMl, 0, 10000)
          );

        // ── /users/{uid}/daily_logs/{date}/meals/{mealId} ─────────────────
        match /meals/{mealId} {
          allow read:   if isSignedIn() && isOwner(uid);

          // Meals are written via the /api/log-food server route (Admin SDK)
          // so client writes are intentionally blocked here
          allow write:  if false;

          // Allow clients to delete their own meals (triggers recalculate function)
          allow delete: if isSignedIn() && isOwner(uid);
        }

        // ── /users/{uid}/daily_logs/{date}/workouts/{workoutId} ───────────
        match /workouts/{workoutId} {
          allow read:   if isSignedIn() && isOwner(uid);
          allow create: if isSignedIn()
            && isOwner(uid)
            && onlyFields(["type", "durationMinutes", "caloriesBurned", "source", "loggedAt"])
            && inRange(request.resource.data.durationMinutes, 1, 600)
            && inRange(request.resource.data.caloriesBurned, 0, 5000);
          allow update: if false; // workouts are immutable once logged
          allow delete: if isSignedIn() && isOwner(uid);
        }
      }

      // ── /users/{uid}/saved_recipes/{recipeId} ───────────────────────────
      match /saved_recipes/{recipeId} {
        allow read:   if isSignedIn() && isOwner(uid);
        allow create: if isSignedIn()
          && isOwner(uid)
          && onlyFields([
              "authorUid", "title", "ingredients",
              "instructions", "macros", "imageUrl", "createdAt"
             ])
          && request.resource.data.authorUid == uid;
        allow update: if isSignedIn() && isOwner(uid);
        allow delete: if isSignedIn() && isOwner(uid);
      }
    }

    // ── Deny everything else by default ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}